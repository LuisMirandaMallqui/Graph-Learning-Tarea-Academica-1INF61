# ============================================================
# .gitignore — RelBench TA-AI PUCP 2026
# ============================================================

# --- Entorno virtual (NUNCA subir) ---
.venv/
venv/
env/
ENV/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
*.dll

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- PyTorch / modelos entrenados ---
*.pt
*.pth
*.ckpt
*.safetensors
checkpoints/
runs/

# --- RelBench cache (datasets se descargan automaticamente) ---
~/.cache/relbench/
.relbench_cache/

# --- Datos (demasiado grandes para git) ---
data/
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.db
*.sqlite
*.pkl
*.pickle
*.npy
*.npz

# --- Resultados / outputs ---
results/
outputs/
logs/
*.log
wandb/
mlruns/

# --- VS Code ---
.vscode/settings.json
.vscode/*.code-workspace

# --- IDEs ---
.idea/
*.iml
.DS_Store
Thumbs.db

# --- Variables de entorno y secretos ---
.env
.env.*
secrets.yaml
secrets.json
*.key

# --- pyenv local ---
.python-version

# --- Windows ---
desktop.ini
$RECYCLE.BIN/

# --- Temporales ---
*.tmp
*.bak
*.swp
*~
